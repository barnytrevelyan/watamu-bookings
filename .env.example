# ===========================================
# Watamu Bookings — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values.

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- Stripe -----
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- M-Pesa (Safaricom Daraja API) -----
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-passkey
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
MPESA_ENV=sandbox

# ----- Application -----
NEXT_PUBLIC_BASE_URL=http://localhost:3000
PLATFORM_COMMISSION_PERCENT=10

# ----- Site chatbot (Claude Haiku) -----
# Powers the /api/chat endpoint and the floating chat widget. Separate from
# WATAMU_AI_API_KEY below (which runs listing import). When unset, the
# endpoint returns 503 and the widget can stay off.
ANTHROPIC_API_KEY=sk-ant-...

# ----- AI Import (OpenAI) -----
# Powers the "free for hosts" AI import when a host doesn't paste their own
# key. OpenAI gpt-4o-mini is the active platform-paid path (cheapest/fastest).
# The importer also supports Anthropic (claude-haiku-4-5) if you set
# WATAMU_AI_PROVIDER=anthropic, but billing alerts below assume OpenAI.
WATAMU_AI_API_KEY=sk-...
WATAMU_AI_PROVIDER=openai

# ----- AI Budget Alerting -----
# /api/cron/check-ai-budget runs daily (see vercel.json). It sums trailing-30d
# platform-paid spend from wb_import_logs and, when it crosses
# WATAMU_AI_ALERT_THRESHOLD_PCT % of WATAMU_AI_MONTHLY_BUDGET_USD, emails the
# alert address via ZeptoMail. Cooldown is 7 days so a single breach does not
# spam the inbox.
WATAMU_AI_MONTHLY_BUDGET_USD=50
WATAMU_AI_ALERT_THRESHOLD_PCT=80
WATAMU_AI_ALERT_EMAIL=barnytrevelyan@gmail.com

# ----- ZeptoMail (transactional email) -----
# Used by the budget-alert cron. Paste the key with or without the
# "Zoho-enczapikey " prefix — the cron normalises it. ZEPTOMAIL_API_URL only
# needs to change for EU/IN regions (default: https://api.zeptomail.com/v1.1/email).
ZEPTOMAIL_TOKEN=Zoho-enczapikey ...
ZEPTOMAIL_FROM_EMAIL=alerts@kwetu.ke
ZEPTOMAIL_FROM_NAME=Kwetu Alerts
ZEPTOMAIL_API_URL=https://api.zeptomail.com/v1.1/email

# Shared secret Vercel Cron sends as `Authorization: Bearer $CRON_SECRET`.
# The cron also accepts `?token=$CRON_SECRET` for manual curl testing.
CRON_SECRET=generate-a-random-string
